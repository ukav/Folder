    if input.KeyCode == Enum.KeyCode.C then
        boss1Running = false
        boss2Running = false
        followModeRunning = false
        updateUI1(false)
        updateUI2(false)
        if FollowToggleBtn then
            TweenService:Create(FollowToggleBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(210, 55, 55)}):Play()
            FollowToggleBtn.Text = "FOLLOW MODE: OFF"
            FollowStatusLabel.Text = "Target: " .. LEADER_NAME .. " (Stopped)"
        end
        camera.FieldOfView = 70
        restoreGameGUIs()
    end
end)

